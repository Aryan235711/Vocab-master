# Required: Google Gemini API key for AI features (mnemonic, context, doubt chat).
# Get one at https://aistudio.google.com/apikey
# On Render: set this in Dashboard → Environment → Environment Variables
GEMINI_API_KEY="your-gemini-api-key-here"

# Optional: port for the Express server (defaults to 3001)
PORT=3001

# Optional: Firebase config for premium features (soft launch toggle, waitlist, founding member tracking).
# Create a Firebase project at https://console.firebase.google.com
# Go to Project Settings → General → Your apps → Web app → Config
# These are public config values (not secrets) — safe to commit or set as build-time env vars.
# If omitted, the app runs in local-only mode (soft_launch defaults to true, waitlist stored locally).
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
